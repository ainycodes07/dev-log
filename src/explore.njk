---
layout: base.njk
title: Explore
---

<section>
    <h1>Explore the Logs</h1>
    <p style="color: var(--text-muted); margin-bottom: 3rem;">Filter by category or browse the full archive.</p>
    
    <h3 style="text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px; margin-bottom: 1.5rem;">Tags</h3>
    <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 4rem;">
        <button class="explore-tag active-tag" data-tag="all">All ({{ collections.posts.length }})</button>
    
    {% for tag in collections.tagList %}
        <button class="explore-tag" data-tag="{{ tag }}">
            {{ tag }} ({{ collections[tag].length }})
        </button>
    {% endfor %}
    </div>

    <h3 style="text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px; margin-bottom: 1.5rem;">Full Archive</h3>
    <ul class="post-list">
      {%- for post in collections.posts | reverse -%}
        <li class="post-item filterable-post" data-tags="{{ post.data.tags | join(',') }}">
          <a href="{{ post.url }}" class="post-link">{{ post.data.title }}</a>
          <span class="post-date">{{ post.date | dateFilter }}</span>
        </li>
      {%- endfor -%}
    </ul>
</section>