<body>
  <header class="site-header">
    <div class="logo"><a href="/">&lt;dev.log&gt;</a></div>
    <nav>
      <a href="/" class="nav-key">Home</a>
      <a href="/explore/" class="nav-key">Explore</a>
      <a href="/about/" class="nav-key">About</a>
    </nav>
  </header>

  <main>
<div class="key-hints">
  <span class="info-icon">i</span> Press <kbd>H</kbd> for Home &nbsp; // &nbsp; Press <kbd>E</kbd> for Explore &nbsp; // &nbsp; Press <kbd>A</kbd> for About
</div>
    {{ content | safe }}
  </main>

  <footer>
    <p>EOF - All systems nominal.</p>
  </footer>

  <script src="/js/main.js" defer></script>
